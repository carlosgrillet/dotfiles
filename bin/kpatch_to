#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<EOF
Usage: kpatch_to PATCH

Output To: recipients (maintainers + reviewers) for a kernel patch or series.
Must be run from the kernel tree root (requires ./scripts/get_maintainer.pl).

Arguments:
  PATCH     Path to a .patch file. If the file matches 0000-* (cover letter),
            recipients are collected across all patches in the same directory.

Options:
  -h, --help    Show this help message and exit

Examples:
  kpatch_to patches/v2-0000-cover-letter.patch
  kpatch_to patches/v2-0001-my-fix.patch

Notes:
  Fallback to linux-kernel@vger.kernel.org if no maintainer is found.
  Intended for use with git send-email --to-cmd=kpatch_to
EOF
}

case "${1:-}" in
    -h|--help) usage; exit 0 ;;
esac

opts=(--nogit-fallback --norolestats)

if [[ $(basename "$1") =~ 0000- ]]; then
    dir=$(dirname "$1")
    patches=()
    for patch in "$dir"/*.patch; do
        [[ $(basename "$patch") =~ 0000- ]] && continue
        patches+=("$patch")
    done
    ./scripts/get_maintainer.pl --nol "${opts[@]}" "${patches[@]}"
else
    maint=$(./scripts/get_maintainer.pl --nol "${opts[@]}" "$1")
    if [[ -z "$maint" ]]; then
        echo "linux-kernel@vger.kernel.org"
    else
        echo "$maint"
    fi
fi
